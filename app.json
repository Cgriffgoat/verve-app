{
  "expo": {
    "name": "Verve",
    "slug": "verve-app",
    "version": "1.0.0",
    "scheme": "verve",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.Chelsea.verve"
    },
    "android": {
      "package": "com.verve.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Verve needs location access to find activities near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Verve needs photo access to let you add pictures to your profile."
        }
      ]
    ]
  }
}
